          "categoryId": "puvfk2toxhs9"
        },
        {
          "subtype": "Cudgel",
          "side": "mundane",
          "tierId": "ajesfpu5xhs9",
          "hasStack": false,
          "stack": 1,
          "fields": {
            "eay8cuxvxhs9": "Fashioned By Addler. A haft of Quori Fig wood studded with cruel metal studs and less intentionally, human teeth.",
            "gcauyfs4xhs9": "6"
          },
          "activeFieldIds": [
