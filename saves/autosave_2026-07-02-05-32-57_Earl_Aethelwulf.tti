        },
        {
          "subtype": "Tools",
          "side": "mundane",
          "tierId": null,
          "hasStack": false,
          "stack": 1,
          "fields": {
            "gcauyfs4xhs9": "25",
            "eay8cuxvxhs9": "Prised from the belt of Addler, these tools may be marked with his hand-scrached name, but they are clearly stolen. a smith's mark Dots the small knives chisels and sanding stones."
          },
          "activeFieldIds": [
            "eay8cuxvxhs9",
            "gcauyfs4xhs9"
          ],
          "createdAt": 1782787211532,
          "inventoryId": "pv8mygn0t9ym",
          "isCollection": false,
          "containerId": null,
          "isDaily": false,
          "isDailyUsed": false,
          "id": "skulf767h4b0",
          "name": "Addler's Woodworking Tool Kit",
          "categoryId": "e4vl1rfzxhs9"
        },
        {
          "subtype": "Fishing Pole",
          "side": "mundane",
          "tierId": null,
          "hasStack": false,
          "stack": 1,
          "fields": {
            "eay8cuxvxhs9": "Belonging to a long-dead brigand. The Pole is covered in notches. Catches? Kills? Lovers? The pole wont say, instead it just spits out splinters under your nails.",
            "gcauyfs4xhs9": "5"
          },
          "activeFieldIds": [
            "eay8cuxvxhs9",
            "gcauyfs4xhs9"
          ],
          "createdAt": 1782786907755,
          "inventoryId": "pv8mygn0t9ym",
          "isCollection": false,
          "containerId": null,
          "isDaily": false,
          "isDailyUsed": false,
          "id": "ney1ovk0alwr",
          "name": "Handmade Notched Fishing Pole",
          "categoryId": "e4vl1rfzxhs9"
        },
        {
          "subtype": "Scythe",
          "side": "mundane",
          "tierId": "6zybtmyrxhs9",
          "hasStack": false,
          "stack": 1,
          "fields": {
            "eay8cuxvxhs9": "Stolen from the farmers' of Maratira, it is too cumbersome to be an effective weapon. It is however a functional if lightly rusted tool. Marked with the seal of a local smith",
            "gcauyfs4xhs9": "15"
          },
          "activeFieldIds": [
            "__quality__",
