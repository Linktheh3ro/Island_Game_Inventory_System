        {
          "subtype": "Monster Body Part",
          "side": "mundane",
          "tierId": null,
          "hasStack": false,
          "stack": 1,
          "fields": {
            "eay8cuxvxhs9": "Smelling of Silt and blood, the head watches. The clean cut across the neck leaks transparent sludge and viscera. The smell is unfathomable. Atop its head a fleshy growth vaguely resembles the shape of a pale woman's upper body.",
            "gcauyfs4xhs9": "85"
          },
