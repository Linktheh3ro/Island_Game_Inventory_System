        },
        {
          "subtype": "Fish",
          "side": "mundane",
          "tierId": null,
          "hasStack": true,
          "stack": 5,
          "fields": {
            "gcauyfs4xhs9": "1",
            "eay8cuxvxhs9": "The Salt is coated thick enough to drown any flavour, the texture is hard leather, the smell, repulsive."
          },
          "activeFieldIds": [
            "gcauyfs4xhs9",
            "eay8cuxvxhs9"
          ],
          "createdAt": 1782786006285,
