          "id": "8tcls24prabx",
          "name": "Old Salted fish",
          "categoryId": "en00etqoxhs9"
        },
        {
          "subtype": "Gamberson",
          "side": "mundane",
          "tierId": "6zybtmyrxhs9",
          "hasStack": false,
          "stack": 1,
          "fields": {
            "eay8cuxvxhs9": "It feels perpetually wet. The Holes are uncountable. Once this thing saved lives, not anymore.",
            "gcauyfs4xhs9": "6",
            "y8no6ri7xhs9": "Light"
          },
          "activeFieldIds": [
            "eay8cuxvxhs9",
