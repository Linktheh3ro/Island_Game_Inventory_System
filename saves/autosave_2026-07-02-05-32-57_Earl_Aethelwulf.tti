          "isCollection": false,
          "containerId": null,
          "isDaily": false,
          "isDailyUsed": false,
          "id": "cn0d9ir5nsh1",
          "name": "Rotten Gaberson",
          "categoryId": "804u5339xhs9"
        },
        {
          "subtype": "Helmet",
          "side": "mundane",
          "tierId": "b4krmmi7xhs9",
          "hasStack": false,
          "stack": 1,
          "fields": {
            "y8no6ri7xhs9": "Medium",
            "gcauyfs4xhs9": "25",
            "eay8cuxvxhs9": "An ugly dent sits on its left brow. Rust flecks its brim. Its straps are frayed and blotched with mould. It has seen countless battles. Its eager to see countless more."
          },
          "activeFieldIds": [
            "eay8cuxvxhs9",
            "gcauyfs4xhs9",
